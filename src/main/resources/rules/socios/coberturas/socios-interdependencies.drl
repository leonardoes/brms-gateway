rule "Garantia Funeral requires M or MA - Socios"
    when
        $cotacao : RequestGlobalvida($socio : socios, $socio.coberturas != null)
        (exists Cobertura(codigoCobertura == "13284") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "13286") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "13292") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17738") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17739") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17740") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17741") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "16772") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "16773") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "16788") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17742") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17743") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17744") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17745") from $socio.getCoberturas())
        not Cobertura(codigoCobertura == "13281") from $socio.getCoberturas()
        not Cobertura(codigoCobertura == "13296") from $socio.getCoberturas()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Garantia Funeral");
        responseRegra.setDevolutiva("Coberturas Garantia Funeral requerem a contratação da cobertura M (13281) ou MA (13296).");
        listaRetornoRegraSocio.add(responseRegra);
end

rule "Garantia Funeral incompatible with AF - Socios"
    when
        $cotacao : RequestGlobalvida($socio : socios, $socio.coberturas != null)
        (exists Cobertura(codigoCobertura == "13284") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "13286") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "13292") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17738") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17739") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17740") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17741") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "16772") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "16773") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "16788") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17742") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17743") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17744") from $socio.getCoberturas()
        or exists Cobertura(codigoCobertura == "17745") from $socio.getCoberturas())
        exists Cobertura(codigoCobertura == "13295") from $socio.getCoberturas()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Garantia Funeral");
        responseRegra.setDevolutiva("Coberturas Garantia Funeral são incompatíveis com a cobertura AF (13295).");
        listaRetornoRegraSocio.add(responseRegra);
end

