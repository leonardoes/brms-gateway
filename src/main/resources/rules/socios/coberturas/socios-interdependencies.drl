package rules.socios.coberturas;

import drools.RetornoRegra;
import contratos.globalvida.request.Cobertura;
import contratos.globalvida.request.Assistencia;
import contratos.globalvida.request.Socio;
import contratos.globalvida.request.RequestGlobalvida;

import java.util.List;

global List<RetornoRegra> listaRetornoRegraSocio;

// Rule: Restricted coverages cannot be contracted together
rule "Coberturas Restritas Incompatíveis - Socios"
    when
        $cotacao : RequestGlobalvida($socio : socios, $socio.coberturas != null)
        $count : Long(this > 1) from accumulate(
            Cobertura(codigoCobertura in ("13284", "13286", "16775", "13292", "17738", "17739", "17740", "17741", "16772", "16773", "16788", "17742", "17743", "17744", "17745")) from $socio.getCoberturas(),
            count()
        )
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Coberturas Restritas");
        responseRegra.setDevolutiva("As coberturas de garantia funeral não podem ser contratadas juntas.");
        listaRetornoRegraSocio.add(responseRegra);
end

rule "IEA requires M - Socios"
    when
        $cotacao : RequestGlobalvida($socio : socios, $socio.coberturas != null)
        exists Cobertura(codigoCobertura == "13293") from $socio.getCoberturas()
        not Cobertura(codigoCobertura == "13281") from $socio.getCoberturas()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("IEA");
        responseRegra.setDevolutiva("Cobertura IEA (13293) requer a contratação da cobertura M (13281).");
        listaRetornoRegraSocio.add(responseRegra);
end

