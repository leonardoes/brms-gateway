package rules.funcionarios.coberturas;

import drools.RetornoRegra;
import contratos.globalvida.request.Cobertura;
import contratos.globalvida.request.Assistencia;
import contratos.globalvida.request.Funcionario;
import contratos.globalvida.request.RequestGlobalvida;

import java.util.List;

global List<RetornoRegra> listaRetornoRegraFuncionario;

// Rule: Restricted coverages cannot be contracted together
rule "Coberturas Restritas Incompatíveis - Funcionarios"
    when
        $cotacao : RequestGlobalvida($funcionario : funcionarios, $funcionario.coberturas != null)
        $count : Long(this > 1) from accumulate(
            Cobertura(codigoCobertura in ("13284", "13286", "16775", "13292", "17738", "17739", "17740", "17741", "16772", "16773", "16788", "17742", "17743", "17744", "17745")) from $funcionario.getCoberturas(),
            count()
        )
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Coberturas Restritas");
        responseRegra.setDevolutiva("As coberturas de garantia funeral não podem ser contratadas juntas.");
        listaRetornoRegraFuncionario.add(responseRegra);
end

// Rule: assistcorp doesn't contracted here
rule "Assistcorp - Funcionarios"
    when
        $cotacao : RequestGlobalvida($funcionario : funcionarios, $funcionario.assistencias != null)
        exists Assistencia(codigoAssistencia == "13305") from $funcionario.getAssistencias()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Assistcorp");
        responseRegra.setDevolutiva("Assistência Corporate somente para Sócios/Diretores.");
        listaRetornoRegraFuncionario.add(responseRegra);
end

// Rule: IEA (13293) requires M (13281) contracted
rule "IEA requires M - Funcionarios"
    when
        $cotacao : RequestGlobalvida($funcionario : funcionarios, $funcionario.coberturas != null)
        exists Cobertura(codigoCobertura == "13293") from $funcionario.getCoberturas()
        not Cobertura(codigoCobertura == "13281") from $funcionario.getCoberturas()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("IEA");
        responseRegra.setDevolutiva("Cobertura IEA (13293) requer a contratação da cobertura M (13281).");
        listaRetornoRegraFuncionario.add(responseRegra);
end

