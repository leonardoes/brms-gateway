// Rule for GFI and GFF coverages
rule "Garantia Funeral requires M or MA - Funcionarios"
    when
        $cotacao : RequestGlobalvida($funcionario : funcionarios, $funcionario.coberturas != null)
        (exists Cobertura(codigoCobertura == "13284") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "13286") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "13292") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17738") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17739") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17740") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17741") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "16772") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "16773") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "16788") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17742") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17743") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17744") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17745") from $funcionario.getCoberturas())
        not Cobertura(codigoCobertura == "13281") from $funcionario.getCoberturas()
        not Cobertura(codigoCobertura == "13296") from $funcionario.getCoberturas()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Garantia Funeral");
        responseRegra.setDevolutiva("Coberturas Garantia Funeral requerem a contratação da cobertura M (13281) ou MA (13296).");
        listaRetornoRegraFuncionario.add(responseRegra);
end

rule "Garantia Funeral incompatible with AF - Funcionarios"
    when
        $cotacao : RequestGlobalvida($funcionario : funcionarios, $funcionario.coberturas != null)
        (exists Cobertura(codigoCobertura == "13284") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "13286") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "13292") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17738") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17739") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17740") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17741") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "16772") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "16773") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "16788") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17742") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17743") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17744") from $funcionario.getCoberturas()
        or exists Cobertura(codigoCobertura == "17745") from $funcionario.getCoberturas())
        exists Cobertura(codigoCobertura == "13295") from $funcionario.getCoberturas()
    then
        RetornoRegra responseRegra = new RetornoRegra();
        responseRegra.setCodigoRetorno(-1L);
        responseRegra.setNomeAmigavel("Garantia Funeral");
        responseRegra.setDevolutiva("Coberturas Garantia Funeral são incompatíveis com a cobertura AF (13295).");
        listaRetornoRegraFuncionario.add(responseRegra);
end

